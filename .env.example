# Server
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173

# REQUIRED: JWT Secret (minimum 32 characters, generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# CORS: Comma-separated allowed origins (optional, defaults to localhost)
# ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
# Local development (host machine, via Docker Compose port mapping):
DATABASE_URL="postgresql://newshub:newshub_dev@localhost:5433/newshub?schema=public"
# Note: localhost:5433 maps to postgres:5432 in Docker (see docker-compose.yml)

# ============================================================================
# DOCKER PRODUCTION (container service names)
# ============================================================================
# When running via `docker compose up`, use container service names instead of
# localhost. These override the local development URLs above.
#
# DATABASE_URL="postgresql://newshub:newshub_dev@postgres:5432/newshub?schema=public"
# REDIS_URL=redis://redis:6379
#
# Note: The docker-compose.yml already sets these in the environment section,
# so you only need to configure them in .env if you want different credentials.

# ============================================================================
# CORS (production whitelist)
# ============================================================================
# Required for production. Comma-separated list of allowed origins.
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# ALLOWED_ORIGINS=http://localhost:3001

# ============================================================================
# PUPPETEER (Docker only - set automatically by Dockerfile)
# ============================================================================
# These are set in the Dockerfile and don't need to be in .env:
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ============================================================================
# REDIS (optional - enables caching and real-time features)
# ============================================================================
# Local: redis://localhost:6379
# Cloud: redis://user:password@host:6379
# REDIS_URL=redis://localhost:6379
# Or use individual settings:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================================================
# EMAIL (optional - enables digests and notifications)
# ============================================================================
# SMTP settings for email digests
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="NewsHub <noreply@newshub.app>"

# ============================================================================
# AI PROVIDERS (at least one required)
# ============================================================================
# Priority: OpenRouter (free) -> Gemini (free) -> Anthropic (paid)
# FALLBACK: If a provider fails, the system automatically tries the next.
# All top providers are FREE - configure multiple for maximum reliability.

# OpenRouter (PRIMARY - Multiple FREE models with auto-fallback!)
# Get your key at: https://openrouter.ai/keys
# Fallback chain (all FREE):
#   1. google/gemma-4-31b-it:free
#   2. google/gemma-4-26b-a4b-it:free
#   3. openai/gpt-oss-120b:free
#   4. z-ai/glm-4.5-air:free
#   5. minimax/minimax-m2.5:free
OPENROUTER_API_KEY=your-openrouter-api-key

# Gemini (FREE tier, 1500 requests/day)
# Get your key at: https://aistudio.google.com/app/apikey
# Fallback chain: gemma-3-27b-it (Gemma 4) -> gemma-2-27b-it (Gemma 3)
# GEMINI_API_KEY=your-gemini-api-key

# Anthropic Claude (Premium - direct API, last resort)
# Get your key at: https://console.anthropic.com/
# Uses model: claude-3-haiku-20240307
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================================
# TRANSLATION PROVIDERS (optional but recommended)
# ============================================================================

# DeepL Translation API (Free tier: 500k chars/month) - BEST QUALITY
# Get your key at: https://www.deepl.com/pro-api
DEEPL_API_KEY=your-deepl-api-key

# Google Translate API (Paid)
# GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# ============================================================================
# NEWS APIS (optional - enables additional sources)
# ============================================================================

# GNews API (100 req/day free): https://gnews.io
GNEWS_API_KEY=your-gnews-api-key

# NewsAPI (100 req/day free): https://newsapi.org
NEWSAPI_KEY=your-newsapi-key

# MediaStack (500 req/month free): https://mediastack.com
MEDIASTACK_API_KEY=your-mediastack-api-key
