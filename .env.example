# Server
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:5173

# REQUIRED: JWT Secret (minimum 32 characters, generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# CORS: Comma-separated allowed origins (optional, defaults to localhost)
# ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ============================================================================
# Database (PostgreSQL via Prisma + PgBouncer in production)
# ============================================================================
# Local dev (single-replica, no PgBouncer):
#   DATABASE_URL="postgresql://newshub:newshub_dev@localhost:5433/newshub?schema=public"
#   (localhost:5433 maps to postgres:5432 in docker-compose.yml)
#
# Production (Phase 37 / DB-01, DB-02):
#   DATABASE_URL="postgres://newshub:${POSTGRES_PASSWORD}@pgbouncer:6432/newshub?pgbouncer=true"
#     - Routes through PgBouncer transaction-pool (port 6432)
#     - ?pgbouncer=true tells Prisma to disable prepared-statement caching (Pitfall 1)
#   DIRECT_URL="postgres://newshub:${POSTGRES_PASSWORD}@postgres:5432/newshub"
#     - Bypasses PgBouncer for `prisma migrate deploy` / `prisma db push`
#     - Required because Schema Engine uses session-scoped connections that
#       transaction-pool mode breaks
DATABASE_URL="postgresql://newshub:newshub_dev@localhost:5433/newshub?schema=public"
DIRECT_URL=                       # Optional in dev; REQUIRED in production (Phase 37 / DB-02)

# ============================================================================
# DOCKER PRODUCTION (container service names)
# ============================================================================
# When running via `docker compose up`, use container service names instead of
# localhost. These override the local development URLs above.
#
# DATABASE_URL="postgresql://newshub:newshub_dev@postgres:5432/newshub?schema=public"
# REDIS_URL=redis://redis:6379
#
# Note: The docker-compose.yml already sets these in the environment section,
# so you only need to configure them in .env if you want different credentials.

# ============================================================================
# CORS (production whitelist)
# ============================================================================
# Required for production. Comma-separated list of allowed origins.
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# ALLOWED_ORIGINS=http://localhost:3001

# ============================================================================
# PUPPETEER (Docker only - set automatically by Dockerfile)
# ============================================================================
# These are set in the Dockerfile and don't need to be in .env:
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ============================================================================
# REDIS (optional - enables caching and real-time features)
# ============================================================================
# Local: redis://localhost:6379
# Cloud: redis://user:password@host:6379
# REDIS_URL=redis://localhost:6379
# Or use individual settings:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================================================
# EMAIL (optional - enables digests and notifications)
# ============================================================================
# SendGrid SMTP (Phase 22)
# Get your API key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
# Webhook verification key (from SendGrid Event Webhook settings)
SENDGRID_WEBHOOK_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxx
# Sender address (must be verified in SendGrid)
SMTP_FROM="NewsHub <noreply@newshub.app>"

# ALERT_EMAIL: Recipient for Prometheus/Alertmanager notifications
# ALERT_EMAIL=ops@example.com

# ============================================================================
# OAUTH PROVIDERS (optional - enables social login)
# ============================================================================
# OAuth enables "Continue with Google/GitHub" login in addition to email/password.
# Users who sign up via OAuth have their email automatically verified.

# GOOGLE OAUTH
# Setup: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: http://localhost:3001/api/auth/google/callback
#    (and your production URL: https://yourdomain.com/api/auth/google/callback)
# 3. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GITHUB OAUTH
# Setup: https://github.com/settings/developers
# 1. Register a new OAuth App
# 2. Set Authorization callback URL: http://localhost:3001/api/auth/github/callback
#    (and your production URL: https://yourdomain.com/api/auth/github/callback)
# 3. Copy Client ID and generate Client Secret below
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAUTH SESSION SECRET (required if using OAuth)
# Generate with: openssl rand -base64 32
# Used for securing OAuth state parameter and session cookies
OAUTH_SESSION_SECRET=

# ============================================================================
# AI PROVIDERS (at least one required)
# ============================================================================
# Priority: OpenRouter (free) -> Gemini (free) -> Anthropic (paid)
# FALLBACK: If a provider fails, the system automatically tries the next.
# All top providers are FREE - configure multiple for maximum reliability.

# OpenRouter (PRIMARY - Multiple FREE models with auto-fallback!)
# Get your key at: https://openrouter.ai/keys
# Fallback chain (all FREE):
#   1. google/gemma-4-31b-it:free
#   2. google/gemma-4-26b-a4b-it:free
#   3. openai/gpt-oss-120b:free
#   4. z-ai/glm-4.5-air:free
#   5. minimax/minimax-m2.5:free
OPENROUTER_API_KEY=your-openrouter-api-key

# Gemini (FREE tier, 1500 requests/day)
# Get your key at: https://aistudio.google.com/app/apikey
# Fallback chain: gemma-3-27b-it (Gemma 4) -> gemma-2-27b-it (Gemma 3)
# GEMINI_API_KEY=your-gemini-api-key

# Anthropic Claude (Premium - direct API, last resort)
# Get your key at: https://console.anthropic.com/
# Uses model: claude-3-haiku-20240307
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================================
# TRANSLATION PROVIDERS (optional but recommended)
# ============================================================================

# DeepL Translation API (Free tier: 500k chars/month) - BEST QUALITY
# Get your key at: https://www.deepl.com/pro-api
DEEPL_API_KEY=your-deepl-api-key

# Google Translate API (Paid)
# GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# ============================================================================
# NEWS APIS (optional - enables additional sources)
# ============================================================================

# GNews API (100 req/day free): https://gnews.io
GNEWS_API_KEY=your-gnews-api-key

# NewsAPI (100 req/day free): https://newsapi.org
NEWSAPI_KEY=your-newsapi-key

# MediaStack (500 req/month free): https://mediastack.com
MEDIASTACK_API_KEY=your-mediastack-api-key

# ============================================================================
# SENTRY ERROR TRACKING (Frontend)
# ============================================================================
# Get your DSN at: https://sentry.io -> Settings -> Projects -> Client Keys (DSN)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2

# ============================================================================
# SENTRY ERROR TRACKING (Backend)
# ============================================================================
# Can use same DSN as frontend or create separate backend project
# Get your DSN at: https://sentry.io -> Settings -> Projects -> Client Keys (DSN)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.2

# ============================================================================
# IMAGE OPTIMIZATION (optional)
# ============================================================================
# Cloudinary cloud name for responsive image transformations
# Enables srcSet, AVIF/WebP format conversion, and auto quality
# If not set, images load from original URLs without optimization
VITE_CLOUDINARY_CLOUD_NAME=

# ============================================================================
# STRIPE (Phase 36 - Monetization)
# ============================================================================
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...

# ============================================================================
# BUILD INFO (set by CI pipeline)
# ============================================================================
BUILD_VERSION=
BUILD_COMMIT=
