// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL defined in prisma.config.ts (Prisma 7+)
}

model NewsArticle {
  id                String   @id
  title             String
  titleTranslated   Json?    // D-13: JSONB stores { de?: string, en?: string }
  content           String
  contentTranslated Json?    // D-13: JSONB stores { de?: string, en?: string }
  summary           String?
  originalLanguage  String
  publishedAt       DateTime
  url               String   @unique
  imageUrl          String?
  sentiment         String
  sentimentScore    Float
  perspective       String
  topics            Json     // D-13: JSONB stores string[]
  entities          Json     // D-13: JSONB stores string[]
  translationQuality Float?
  cached            Boolean  @default(false)
  confidence        Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  source            NewsSource @relation(fields: [sourceId], references: [id])
  sourceId          String

  @@index([publishedAt])
  @@index([perspective])
  @@index([sentiment])
  @@index([sourceId])
  @@index([publishedAt, perspective])  // Dashboard: filtered timeline
  @@index([sentiment, publishedAt])    // Sentiment charts
  @@index([topics(ops: JsonbPathOps)], type: Gin)    // D-14: GIN for topics
  @@index([entities(ops: JsonbPathOps)], type: Gin)  // D-14: GIN for entities
}

model NewsSource {
  id           String   @id
  name         String
  country      String
  region       String
  language     String
  politicalBias Float
  reliability  Int
  ownership    String
  apiEndpoint  String?
  rateLimit    Int
  lastFetched  DateTime?
  articles     NewsArticle[]

  @@index([region])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  bookmarks    Bookmark[]
  readingHistory ReadingHistory[]
  preferences  Json?    // D-13: JSONB stores user preferences

  // Email verification (AUTH-01 per D-51)
  emailVerified          Boolean   @default(false)
  verificationTokenHash  String?
  verificationTokenExpiry DateTime?
  verificationSendCount  Int       @default(0)
  lastVerificationSentAt DateTime?

  // Password reset (AUTH-02 per D-51)
  resetTokenHash         String?
  resetTokenExpiry       DateTime?
  resetSendCount         Int       @default(0)
  lastResetSentAt        DateTime?

  // Session invalidation (D-27, D-28)
  tokenVersion           Int       @default(0)

  // OAuth Integration (Phase 26)
  googleIdHash     String?   @unique  // D-11: SHA-256 hash of Google provider ID
  githubIdHash     String?   @unique  // D-11: SHA-256 hash of GitHub provider ID
  hasPassword      Boolean   @default(true)  // D-03: false for OAuth-only accounts

  // Phase 22: Email bounce/opt-out tracking (D-04, D-07, D-30)
  emailBounced      Boolean   @default(false)
  emailBouncedAt    DateTime?
  emailOptOut       Boolean   @default(false)
  emailOptOutAt     DateTime?

  // Required for cleanup job (D-17)
  updatedAt              DateTime  @updatedAt

  // Phase 6: Profile & Gamification
  avatarUrl            String?
  selectedPresetAvatar String?
  featuredBadgeId      String?
  showOnLeaderboard    Boolean   @default(true)
  isHistoryPaused      Boolean   @default(false)

  // Phase 6: Account deletion (D-69, D-70)
  deletionRequestedAt  DateTime?
  deletionConfirmToken String?

  // Relations for features
  emailSubscription EmailSubscription?
  emailDigests      EmailDigest[]
  userPersonas      UserPersona[]
  badges            UserBadge[]
  comments          Comment[]

  // Indexes for token lookups (D-53)
  @@index([verificationTokenHash])
  @@index([resetTokenHash])
  @@index([emailVerified, createdAt])  // For cleanup job queries
  @@index([googleIdHash])
  @@index([githubIdHash])
}

model Bookmark {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  articleId String
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([userId])
}

model ReadingHistory {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  articleId String
  title     String?
  source    String?
  readAt    DateTime @default(now())

  @@unique([userId, articleId, readAt])
  @@index([userId])
  @@index([readAt])
}

model StoryCluster {
  id                 String   @id @default(cuid())
  canonicalTitle     String
  articles           Json     // D-13: JSONB stores string[] of article IDs
  perspectives       Json     // D-13: JSONB stores string[]
  biasDistribution   Json     // D-13: JSONB stores object
  framingDifferences Json     // D-13: JSONB stores object
  significance       Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([createdAt])
}

// ============================================================================
// EMAIL DIGEST FEATURE
// ============================================================================

model EmailSubscription {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  email         String
  frequency     String   // daily, weekly, realtime
  regions       Json     // D-13: JSONB array of regions to include
  topics        Json     // D-13: JSONB array of topics to include
  minSeverity   String   @default("medium") // critical, high, medium, low
  isActive      Boolean  @default(true)
  lastSentAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId])
  @@index([frequency])
  @@index([isActive])
}

model EmailDigest {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  articleIds    Json     // D-13: JSONB array of article IDs included
  subject       String
  htmlContent   String
  sentAt        DateTime?
  status        String   @default("pending") // pending, sent, failed
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// AI PERSONAS FEATURE
// ============================================================================

model AIPersona {
  id            String   @id @default(cuid())
  name          String
  description   String
  systemPrompt  String   // The AI's personality/perspective prompt
  icon          String?  // Emoji or icon identifier
  color         String?  // Hex color for UI
  isDefault     Boolean  @default(false)
  isPublic      Boolean  @default(true) // Available to all users
  createdBy     String?  // User ID if custom persona
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userPersonas  UserPersona[]

  @@index([isPublic])
  @@index([isDefault])
}

model UserPersona {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  persona     AIPersona @relation(fields: [personaId], references: [id], onDelete: Cascade)
  personaId   String
  isActive    Boolean   @default(false) // Currently selected persona
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, personaId])
  @@index([userId])
}

// ============================================================================
// SOCIAL SHARING FEATURE
// ============================================================================

model SharedContent {
  id            String   @id @default(cuid())
  shareCode     String   @unique // Short unique code for URL
  contentType   String   // article, cluster, comparison, digest
  contentId     String   // ID of the shared content
  title         String
  description   String?
  imageUrl      String?
  createdBy     String?  // User ID if logged in
  viewCount     Int      @default(0)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())

  clicks        ShareClick[]

  @@index([shareCode])
  @@index([contentType])
  @@index([contentId])  // Lookup by content
  @@index([createdAt])
}

model ShareClick {
  id            String   @id @default(cuid())
  sharedContent SharedContent @relation(fields: [sharedContentId], references: [id], onDelete: Cascade)
  sharedContentId String
  platform      String   // twitter, facebook, linkedin, whatsapp, telegram, copy, email
  referrer      String?
  userAgent     String?
  ipHash        String?  // Hashed IP for analytics (privacy-friendly)
  createdAt     DateTime @default(now())

  @@index([sharedContentId])
  @@index([platform])
  @@index([createdAt])
}

// ============================================================================
// PHASE 6: GAMIFICATION & READING HISTORY
// ============================================================================

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  tier        String   // bronze, silver, gold, platinum (D-41)
  category    String   // volume, diversity, behavior (D-42)
  iconType    String   // emoji identifier for icon
  threshold   Int      // Required value to earn this tier
  createdAt   DateTime @default(now())

  userBadges  UserBadge[]

  @@index([category])
  @@index([tier])
}

model UserBadge {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId   String
  earnedAt  DateTime @default(now())
  progress  Int      @default(0)  // Current progress toward next tier

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model LeaderboardSnapshot {
  id        String   @id @default(cuid())
  date      DateTime
  timeframe String   // all-time, monthly, weekly (D-57)
  rankings  Json     // D-13: JSONB stores top 100 users (D-51)
  createdAt DateTime @default(now())

  @@index([date, timeframe])
  @@index([timeframe])
}

// ============================================================================
// PHASE 27: COMMENTS SYSTEM
// ============================================================================

model Comment {
  id              String    @id @default(cuid())
  text            String    @db.VarChar(5000)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  articleId       String

  // Self-referencing relation for threading
  parentComment   Comment?  @relation("Replies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentId        String?
  replies         Comment[] @relation("Replies")

  isDeleted       Boolean   @default(false)
  isEdited        Boolean   @default(false)
  isFlagged       Boolean   @default(false)
  flagReasons     Json?
  aiModerated     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([articleId])
  @@index([userId])
  @@index([parentId])
  @@index([isFlagged])
  @@index([createdAt])
}
