# ============================================================================
# apps/web/.env.example — workspace-local env template
# ============================================================================
# Loaded by `dotenv/config` in apps/web/prisma.config.ts when running Prisma
# CLI commands from this directory (e.g. `cd apps/web && npx prisma db push`).
#
# The root .env.example covers the full application env surface used by
# `pnpm dev` from the repo root. This file focuses on the variables Prisma
# tooling needs — primarily the dual DATABASE_URL / DIRECT_URL pair that
# Phase 37 introduced for PgBouncer-fronted production deploys.

# ============================================================================
# Database (PostgreSQL via Prisma + PgBouncer in production)
# ============================================================================
# Local dev (single-replica, no PgBouncer):
#   DATABASE_URL="postgresql://newshub:newshub_dev@localhost:5433/newshub?schema=public"
#
# Production (Phase 37 / DB-01, DB-02):
#   DATABASE_URL="postgres://newshub:${POSTGRES_PASSWORD}@pgbouncer:6432/newshub?pgbouncer=true"
#     - Routes through PgBouncer transaction-pool (port 6432)
#     - ?pgbouncer=true tells Prisma to disable prepared-statement caching (Pitfall 1)
#   DIRECT_URL="postgres://newshub:${POSTGRES_PASSWORD}@postgres:5432/newshub"
#     - Bypasses PgBouncer for `prisma migrate deploy` / `prisma db push`
#     - Required because Schema Engine uses session-scoped connections that
#       transaction-pool mode breaks
DATABASE_URL="postgresql://newshub:newshub_dev@localhost:5433/newshub?schema=public"
DIRECT_URL=                       # Optional in dev; REQUIRED in production (Phase 37 / DB-02)

# ============================================================================
# Podcast Index API (Phase 40-03 / CONT-03) — primary podcast search
# ============================================================================
# Sign up at https://api.podcastindex.org/ ; both values required to enable
# Podcast Index search. When unset, PodcastIndexService gracefully degrades
# (returns empty results + warn-log; never throws). Authentication uses
# HMAC SHA-1: sha1(KEY + SECRET + unixTimeSeconds), lowercase hex.
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=
