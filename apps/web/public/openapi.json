              },
              "RateLimit-Reset": {
                "description": "Seconds until window resets",
                "schema": {
                  "type": "integer",
                  "example": 45
                }
              },
              "Retry-After": {
                "description": "Seconds to wait before retry",
                "schema": {
                  "type": "integer",
                  "example": 45
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateLimitErrorResponse"
