{
  "name": "newshub-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @newshub/web dev",
    "dev:frontend": "pnpm --filter @newshub/web dev:frontend",
    "dev:backend": "pnpm --filter @newshub/web dev:backend",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @newshub/web test",
    "test:run": "pnpm --filter @newshub/web test:run",
    "test:coverage": "pnpm --filter @newshub/web test:coverage",
    "test:e2e": "pnpm --filter @newshub/web test:e2e",
    "test:e2e:headed": "pnpm --filter @newshub/web test:e2e:headed",
    "test:e2e:ui": "pnpm --filter @newshub/web test:e2e:ui",
    "lint": "pnpm -r lint",
    "seed": "pnpm --filter @newshub/web seed",
    "seed:badges": "pnpm --filter @newshub/web seed:badges",
    "seed:personas": "pnpm --filter @newshub/web seed:personas",
    "seed:load-test": "pnpm --filter @newshub/web seed:load-test",
    "load:smoke": "pnpm --filter @newshub/web load:smoke",
    "load:full": "pnpm --filter @newshub/web load:full",
    "validate:ci": "npx --yes action-validator .github/workflows/ci.yml"
  },
  "devDependencies": {
    "typescript": "~6.0.3"
  }
}
