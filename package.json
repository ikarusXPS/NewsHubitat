{
  "name": "newshub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.5",
      "@hono/node-server": ">=1.19.13"
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch server/index.ts",
    "build": "npm run build:frontend && npm run build:server",
    "build:frontend": "vite build",
    "build:server": "tsup",
    "start": "node --import ./server/instrument.mjs dist/server/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "screenshots": "playwright test e2e/screenshots.spec.ts --project=chromium",
    "seed": "npx tsx prisma/seed.ts",
    "seed:badges": "npx tsx prisma/seed-badges.ts",
    "seed:personas": "npx tsx prisma/seed-personas.ts",
    "seed:load-test": "tsx scripts/seed-load-test-users.js",
    "load:smoke": "k6 run k6/load-test.js --env K6_SCENARIO=smoke",
    "load:full": "k6 run k6/load-test.js --env K6_SCENARIO=load",
    "validate:ci": "npx --yes action-validator .github/workflows/ci.yml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@sendgrid/eventwebhook": "^8.0.0",
    "@sentry/node": "^10.49.0",
    "@sentry/react": "^10.49.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/compression": "^1.8.1",
    "@types/leaflet": "^1.9.21",
    "@types/multer": "^2.1.0",
    "@types/three": "^0.184.0",
