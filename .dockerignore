# =============================================================================
# .dockerignore — pnpm monorepo (Phase 37.1)
# Trim build context aggressively. Workspace node_modules and dist artifacts
# are rebuilt inside the image; never copy them in.
# =============================================================================

# Dependencies (workspace + root)
node_modules
**/node_modules
apps/web/node_modules
packages/*/node_modules
.pnpm-store
e2e-stack/node_modules
npm-debug.log
yarn-error.log
pnpm-debug.log*

# Build outputs (rebuilt in container)
dist
**/dist
apps/web/dist
apps/web/.vite
coverage
.nyc_output
*.log
*.tsbuildinfo

# Generated Prisma client (regenerated by the builder/runner stages)
apps/web/src/generated/prisma
src/generated/prisma

# VCS / IDE / Claude / Planning
.git
.gitignore
.gitattributes
.github
.gitlab-ci.yml
.vscode
.idea
.continue-here.md
.claude
.claude/worktrees
.planning

# Worktrees + temp artifacts
.planning/tmp
.planning/debug

# Tests + dev fixtures
*.test.ts
*.test.tsx
*.spec.ts
__tests__
__mocks__
playwright-report
test-results
playwright/.auth
e2e-stack/playwright-report
e2e-stack/.env

# Docker meta (not needed in build context)
Dockerfile*
docker-compose*
.dockerignore

# Documentation (not needed at runtime)
*.md
docs
LICENSE

# Secrets / env files
.env
.env.*
!.env.example

# Local DB files
dev.db
*.db

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
